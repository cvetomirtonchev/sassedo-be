# Copy to .env and fill in real values. .env is git-ignored and must never be committed.
# Used by docker compose and deploy/init-letsencrypt.sh on the Ubuntu 24.04 host.

# --- Public site / TLS -------------------------------------------------------
# Fully-qualified domain that points (A/AAAA record) at this server.
APP_DOMAIN=api.sassedo.com
# Email used for Let's Encrypt registration and expiry notices.
LETSENCRYPT_EMAIL=admin@example.com
# Set to 1 to use the Let's Encrypt staging CA while testing (avoids rate limits).
LETSENCRYPT_STAGING=0

# --- Database ----------------------------------------------------------------
MYSQL_DATABASE=sassedodb
MYSQL_USER=sassedo
# Use strong, unique values. Rotate the passwords previously committed to git.
MYSQL_PASSWORD=Tonchev1
MYSQL_ROOT_PASSWORD=Tonchev1

# --- Application secrets -----------------------------------------------------
# Long random string used to sign JWTs (e.g. `openssl rand -base64 48`).
JWT_SECRET=change-me-long-random-jwt-secret

# --- Mail (SMTP) -------------------------------------------------------------
MAIL_HOST=mail.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=change-me-smtp-password

# --- Frontend ----------------------------------------------------------------
CLIENT_URL=https://sassedo.com

# --- JVM (optional) ----------------------------------------------------------
JAVA_OPTS=-Xms128m -Xmx768m -XX:MaxMetaspaceSize=192m -Xss512k
