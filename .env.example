# Copy to .env and fill in real values. .env is git-ignored and must never be committed.
# Used by docker compose and deploy/init-letsencrypt.sh on the Ubuntu 24.04 host.

# --- Public site / TLS -------------------------------------------------------
# Fully-qualified domain that points (A/AAAA record) at this server.
APP_DOMAIN=api.sassedo.com
# Email used for Let's Encrypt registration and expiry notices.
LETSENCRYPT_EMAIL=admin@example.com
# Set to 1 to use the Let's Encrypt staging CA while testing (avoids rate limits).
LETSENCRYPT_STAGING=0

# --- Database ----------------------------------------------------------------
MYSQL_DATABASE=sassedodb
MYSQL_USER=sassedo
# Use strong, unique values. Rotate the passwords previously committed to git.
MYSQL_PASSWORD=Tonchev1
MYSQL_ROOT_PASSWORD=Tonchev1

# --- Application secrets -----------------------------------------------------
# Long random string used to sign JWTs (e.g. `openssl rand -base64 48`).
JWT_SECRET=change-me-long-random-jwt-secret

# --- Mail (SMTP) -------------------------------------------------------------
MAIL_HOST=mail.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=change-me-smtp-password

# --- Frontend ----------------------------------------------------------------
CLIENT_URL=https://sassedo-fe.vercel.app

# --- Promotion payments ------------------------------------------------------
# Keep mock until both Stripe secrets are configured. The webhook signing secret is
# different from the Stripe API secret and starts with whsec_.
SASSEDO_PAYMENTS_PROVIDER=mock
STRIPE_SECRET_KEY=sk_test_51Tvz6GRzAXFY20EHKT9RryzmDeNzZGoJVmTuEOKh8pnn4H9cLTfwqA5Aa0OC4u4LctulIGtXPOVMETSzraggBCAu00zo7dtwIy
STRIPE_WEBHOOK_SECRET=pk_test_51Tvz6GRzAXFY20EH2rlqZ2W5UnKtwXgpeYNVZpP4wzimIFiFZkwMZRQXOVd4OiCGEYi5AGg2vp2911plDW8cuiL500ShuVrulz
# Test deployment webhook:
# https://51.102.125.219.sslip.io/api/payments/webhook/stripe

# --- JVM (optional) ----------------------------------------------------------
# Sized to fit the app's mem_limit (1152m) with headroom for metaspace, threads,
# and native memory. ExitOnOutOfMemoryError lets Docker's restart policy recover
# instead of thrashing the host; GC + heap-dump logs land in the app-logs volume.
JAVA_OPTS="-Xms128m -Xmx768m -XX:MaxMetaspaceSize=160m -Xss512k -XX:+UseSerialGC -XX:+ExitOnOutOfMemoryError -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/app/logs -Xlog:gc*:file=/app/logs/gc.log:time,uptime:filecount=3,filesize=10m"
